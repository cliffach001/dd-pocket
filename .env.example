# Supabase Configuration
# Dapatkan URL dan Anon Key dari Project Settings > API di dashboard Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role Key (server-side only)
# Untuk upload file ke Supabase Storage bucket "images"
# Dapatkan dari Supabase Dashboard → Settings → API → service_role key
# Jangan pernah expose key ini ke client/browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
